<Page x:Class="DokterApp.PatientWijzigenPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Patiënt wijzigen"
      Loaded="Page_Loaded">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Paginatitel -->
        <TextBlock Grid.Row="0" Text="Patiënt wijzigen"
                   FontSize="22" FontWeight="Bold" Margin="0,0,0,6" />

        <!-- Info: welke velden de dokter kan wijzigen -->
        <TextBlock Grid.Row="1"
                   Text="Als dokter kunt u de naam, contactgegevens en geboortedatum wijzigen."
                   Foreground="#555555" FontSize="12" Margin="0,0,0,14" />

        <!-- Foutmelding -->
        <TextBlock Grid.Row="2" x:Name="TxtFout"
                   Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,10" />

        <!-- Formulier: enkel de velden die een dokter mag wijzigen -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <Grid MaxWidth="500" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Voornaam -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Voornaam *:"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,0,8" />
                <TextBox Grid.Row="0" Grid.Column="1"
                         x:Name="TxtVoornaam" Padding="6,4" Margin="0,0,0,8" />

                <!-- Achternaam -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Achternaam *:"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,0,8" />
                <TextBox Grid.Row="1" Grid.Column="1"
                         x:Name="TxtAchternaam" Padding="6,4" Margin="0,0,0,8" />

                <!-- E-mail -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="E-mail *:"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,0,8" />
                <TextBox Grid.Row="2" Grid.Column="1"
                         x:Name="TxtEmail" Padding="6,4" Margin="0,0,0,8" />

                <!-- Telefoonnummer -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Telefoonnummer:"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,0,8" />
                <TextBox Grid.Row="3" Grid.Column="1"
                         x:Name="TxtGsm" Padding="6,4" Margin="0,0,0,8" />

                <!-- Geboortedatum -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Geboortedatum *:"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,0,8" />
                <TextBox Grid.Row="4" Grid.Column="1"
                         x:Name="TxtGeboortedatum" Padding="6,4" Margin="0,0,0,8"
                         ToolTip="Formaat: dd/MM/yyyy" />
            </Grid>
        </ScrollViewer>

        <!-- Actieknoppen -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,16,0,0">
            <Button Content="Opslaan"        Click="BtnOpslaan_Click"
                    Padding="18,6" Margin="0,0,10,0" />
            <Button Content="Annuleren"      Click="BtnAnnuleren_Click"
                    Padding="18,6" Margin="0,0,10,0" />
            <Button Content="Naar overzicht" Click="BtnNaarOverzicht_Click"
                    Padding="18,6" />
        </StackPanel>
    </Grid>
</Page>
