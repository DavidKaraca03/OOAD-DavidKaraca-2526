<Window x:Class="DokterApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DokterApp"
        mc:Ignorable="d"
        Title="DoktorsPortaal – Dokter" Height="600" Width="960"
        Loaded="Window_Loaded">
    <Window.Resources>
        <!-- Stijl voor navknoppen: transparant met hover-highlight en afgeronde hoeken -->
        <Style x:Key="NavKnop" TargetType="Button">
            <Setter Property="Foreground" Value="#C8DEF0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Rand" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                Margin="8,2">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Rand" Property="Background" Value="#3D5A73" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Rand" Property="Background" Value="#1F3548" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel>
        <!-- Bovenste balk met naam en foto van de ingelogde dokter, verborgen tot na login -->
        <Border x:Name="TopBar" DockPanel.Dock="Top" Visibility="Collapsed"
                Background="#1A252F" Padding="10,6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="LblGebruikerNaam"
                           Foreground="White" VerticalAlignment="Center"
                           FontWeight="SemiBold" Margin="0,0,10,0" />
                <!-- Profielfoto of initiaal als placeholder -->
                <Grid Width="36" Height="36">
                    <Border Background="#3D6B8F" CornerRadius="18" />
                    <TextBlock x:Name="LblGebruikerInitiaal"
                               Foreground="White" FontWeight="Bold" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Image x:Name="ImgGebruikerFoto" Width="36" Height="36"
                           Stretch="UniformToFill" Visibility="Collapsed" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Linker navigatiepaneel, verborgen tot na login -->
        <StackPanel x:Name="NavPanel" DockPanel.Dock="Left" Width="160"
                    Background="#2C3E50" Visibility="Collapsed">
            <!-- Logo en app naam bovenaan het menu -->
            <Border Background="#1A2B38" Padding="10,14,10,12">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🏥" FontSize="28" HorizontalAlignment="Center" />
                    <TextBlock Text="DoktorsPortaal" Foreground="White" FontWeight="Bold"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               TextAlignment="Center" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Button Content="📅  Afspraken" Margin="0,10,0,0"
                    Click="BtnAfspraken_Click" Style="{StaticResource NavKnop}" />
            <Button Content="👥  Patiënten"
                    Click="BtnPatienten_Click" Style="{StaticResource NavKnop}" />
            <Button Content="🚪  Afmelden"  Margin="0,12,0,0"
                    Click="BtnAfmelden_Click" Style="{StaticResource NavKnop}" />
        </StackPanel>

        <!-- Hoofdframe voor paginanavigatie -->
        <Frame x:Name="HoofdFrame" NavigationUIVisibility="Hidden" />
    </DockPanel>
</Window>
