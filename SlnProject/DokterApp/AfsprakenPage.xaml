<Page x:Class="DokterApp.AfsprakenPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Afspraken"
      Loaded="Page_Loaded">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <!-- Linker kolom: kalender -->
            <ColumnDefinition Width="Auto" />
            <!-- Rechter kolom: afsprakenoverzicht -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Kalender -->
        <StackPanel Grid.Column="0" Margin="0,0,24,0">
            <TextBlock Text="Selecteer een datum"
                       FontWeight="Bold" Margin="0,0,0,8" />
            <Calendar x:Name="Kalender"
                      SelectedDatesChanged="Kalender_SelectionChanged" />
        </StackPanel>

        <!-- Afsprakenoverzicht -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <!-- Details van geselecteerde afspraak -->
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Datum als header -->
            <TextBlock Grid.Row="0" x:Name="TxtDatumHeader"
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,6" />

            <!-- Foutmelding -->
            <TextBlock Grid.Row="1" x:Name="TxtFout"
                       Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,8" />

            <!-- Lijst van afspraken als cards -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="PnlAfspraken" />
            </ScrollViewer>

            <!-- Details van de geselecteerde afspraak, verborgen tot selectie -->
            <Border Grid.Row="3" x:Name="PnlGeselecteerd"
                    Visibility="Collapsed"
                    BorderBrush="#2C3E50" BorderThickness="1"
                    CornerRadius="4" Padding="14" Margin="0,12,0,0"
                    Background="#F4F6F7">
                <StackPanel>
                    <!-- Tijdstip en patiënt van de geselecteerde afspraak -->
                    <TextBlock x:Name="LblGeselecteerdHeader"
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,6" />
                    <!-- Klacht / reden van bezoek -->
                    <TextBlock Text="Reden van consultatie:" FontWeight="SemiBold" Margin="0,0,0,2" />
                    <TextBlock x:Name="LblGeselecteerdKlacht"
                               TextWrapping="Wrap" Margin="0,0,0,12" />
                    <!-- Annuleerknop -->
                    <Button x:Name="BtnAnnuleren" Content="Afspraak annuleren"
                            Click="BtnAnnuleren_Click"
                            Visibility="Collapsed"
                            HorizontalAlignment="Left" Padding="12,5"
                            Foreground="White" Background="#C0392B" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
