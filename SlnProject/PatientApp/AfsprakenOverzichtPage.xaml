<Page x:Class="PatientApp.AfsprakenOverzichtPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Mijn afspraken"
      Loaded="Page_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- Paginatitel -->
            <RowDefinition Height="Auto" />
            <!-- Knop nieuwe afspraak -->
            <RowDefinition Height="Auto" />
            <!-- Foutmelding -->
            <RowDefinition Height="Auto" />
            <!-- Afsprakenlijst -->
            <RowDefinition Height="*" />
            <!-- Details van geselecteerde afspraak -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Paginatitel -->
        <TextBlock Grid.Row="0" Text="Mijn afspraken"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,12" />

        <!-- Knop om een nieuwe afspraak te maken -->
        <Button Grid.Row="1" Content="+ Nieuwe afspraak"
                HorizontalAlignment="Left" Padding="10,5"
                Margin="0,0,0,12" Click="BtnNieuweAfspraak_Click" />

        <!-- Foutmelding -->
        <TextBlock Grid.Row="2" x:Name="TxtFout"
                   Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,8" />

        <!-- Scrollbare lijst van afspraken als cards -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="PnlAfspraken" />
        </ScrollViewer>

        <!-- Details van de geselecteerde afspraak, verborgen tot selectie -->
        <Border Grid.Row="4" x:Name="PnlGeselecteerd"
                Visibility="Collapsed"
                BorderBrush="#1A5276" BorderThickness="1"
                CornerRadius="4" Padding="14" Margin="0,12,0,0"
                Background="#EBF5FB">
            <StackPanel>
                <!-- Datum, tijdstip en dokter van de geselecteerde afspraak -->
                <TextBlock x:Name="LblGeselecteerdHeader"
                           FontWeight="Bold" FontSize="14" Margin="0,0,0,6" />
                <!-- Klacht / reden van bezoek -->
                <TextBlock Text="Reden van consultatie:" FontWeight="SemiBold" Margin="0,0,0,2" />
                <TextBlock x:Name="LblGeselecteerdKlacht"
                           TextWrapping="Wrap" Margin="0,0,0,12" />
                <!-- Annuleerknop: alleen zichtbaar als de afspraak in de toekomst ligt -->
                <Button x:Name="BtnAnnuleren" Content="Afspraak annuleren"
                        Click="BtnAnnuleren_Click"
                        Visibility="Collapsed"
                        HorizontalAlignment="Left" Padding="12,5"
                        Foreground="White" Background="#C0392B" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
