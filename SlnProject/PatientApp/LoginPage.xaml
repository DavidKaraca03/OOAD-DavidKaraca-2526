<Page x:Class="PatientApp.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Inloggen">

    <Page.Resources>
        <!-- Knopstijl met hover-effect en afgeronde hoeken -->
        <Style x:Key="PrimaireKnop" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Rand" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Rand" Property="Background" Value="#1A6E9A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Rand" Property="Background" Value="#083D58" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Linker brandingpaneel -->
            <ColumnDefinition Width="2.2*" />
            <!-- Rechter formulierpaneel -->
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════ LINKER PANEEL: branding ═══════════════════ -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#061E2B" Offset="0" />
                    <GradientStop Color="#0C3547" Offset="0.55" />
                    <GradientStop Color="#154E6E" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="40,0" MaxWidth="280">
                <!-- Logo -->
                <TextBlock Text="🏥" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,16" />
                <TextBlock Text="DoktorsPortaal" FontSize="26" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6" />
                <TextBlock Text="Patiënt applicatie" FontSize="13" Foreground="#7EC8D8"
                           HorizontalAlignment="Center" Margin="0,0,0,44" />

                <!-- Scheidingslijn -->
                <Border Height="1" Margin="0,0,0,32">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0" />
                            <GradientStop Color="#2A7A9A" Offset="0.5" />
                            <GradientStop Color="Transparent" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Feature bullets -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="✓" Foreground="#3DAFCC" FontWeight="Bold" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Text="Uw afspraken bekijken en annuleren" Foreground="#A8D8E8" FontSize="13" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="✓" Foreground="#3DAFCC" FontWeight="Bold" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Text="Nieuwe afspraken inplannen" Foreground="#A8D8E8" FontSize="13" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✓" Foreground="#3DAFCC" FontWeight="Bold" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Text="Uw profielgegevens beheren" Foreground="#A8D8E8" FontSize="13" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════════ RECHTER PANEEL: formulier ═══════════════════ -->
        <Border Grid.Column="1" Background="#F0F7FA">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Width="360" Margin="40,0">

                <!-- Welkomtekst -->
                <TextBlock Text="Welkom terug 👋" FontSize="26" FontWeight="Bold"
                           Foreground="#1E293B" Margin="0,0,0,6" />
                <TextBlock Text="Meld u aan om uw afspraken te bekijken en te beheren."
                           FontSize="13" Foreground="#64748B" TextWrapping="Wrap"
                           Margin="0,0,0,36" />

                <!-- E-mail veld -->
                <TextBlock Text="E-mailadres" FontSize="13" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,0,0,6" />
                <Border BorderBrush="#B2D6E8" BorderThickness="1.5" CornerRadius="7"
                        Background="White" Margin="0,0,0,18">
                    <TextBox x:Name="TxtEmail"
                             Padding="13,11" FontSize="14"
                             BorderThickness="0" Background="Transparent"
                             FocusVisualStyle="{x:Null}" />
                </Border>

                <!-- Wachtwoord veld -->
                <TextBlock Text="Wachtwoord" FontSize="13" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,0,0,6" />
                <Border BorderBrush="#B2D6E8" BorderThickness="1.5" CornerRadius="7"
                        Background="White" Margin="0,0,0,28">
                    <PasswordBox x:Name="TxtPaswoord"
                                 Padding="13,11" FontSize="14"
                                 BorderThickness="0" Background="Transparent" />
                </Border>

                <!-- Login knop -->
                <Button Content="Aanmelden →" Click="BtnInloggen_Click"
                        HorizontalAlignment="Stretch" Padding="0,14"
                        Background="#0C3547"
                        Style="{StaticResource PrimaireKnop}" />

                <!-- Foutmelding (enkel zichtbaar bij fout) -->
                <Border x:Name="PnlFout" Visibility="Collapsed"
                        Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
                        CornerRadius="7" Padding="14,10" Margin="0,20,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" Foreground="#DC2626" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock x:Name="TxtFout" Foreground="#DC2626"
                                   TextWrapping="Wrap" FontSize="13"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Page>
