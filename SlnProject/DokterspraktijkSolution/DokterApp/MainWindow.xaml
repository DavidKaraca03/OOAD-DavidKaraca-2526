<Window x:Class="DokterApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DokterApp"
        mc:Ignorable="d"
        Title="Dokterspraktijk – Dokter" Height="600" Width="900"
        Loaded="Window_Loaded">
    <DockPanel>
        <!-- Linker navigatiepaneel, verborgen tot na login -->
        <StackPanel x:Name="NavPanel" DockPanel.Dock="Left" Width="160"
                    Background="#2C3E50" Visibility="Collapsed">
            <Button Content="Afspraken"  Margin="10,20,10,5" />
            <Button Content="Patiënten"  Margin="10,5,10,5" />
            <Button Content="Afmelden"   Margin="10,5,10,5" />
        </StackPanel>
        <!-- Hoofdframe voor paginanavigatie -->
        <Frame x:Name="HoofdFrame" NavigationUIVisibility="Hidden" />
    </DockPanel>
</Window>
