<Page x:Class="DokterApp.PatientenOverzichtPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Patiëntenoverzicht"
      Loaded="Page_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- Zoekbalk -->
            <RowDefinition Height="Auto" />
            <!-- Foutmelding -->
            <RowDefinition Height="Auto" />
            <!-- Patiëntenkaarten -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Zoekbalk bovenaan -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox x:Name="TxtZoek" Width="260" Padding="6,4"
                     Margin="0,0,8,0" />
            <Button Content="Zoeken" Click="BtnZoeken_Click"
                    Padding="14,4" Margin="0,0,8,0" />
            <Button Content="Alle patiënten" Click="BtnAlles_Click"
                    Padding="14,4" Margin="0,0,16,0" />
            <Button Content="+ Nieuwe patiënt" Click="BtnNieuw_Click"
                    Padding="14,4" />
        </StackPanel>

        <!-- Foutmelding -->
        <TextBlock Grid.Row="1" x:Name="TxtFout"
                   Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,8" />

        <!-- Scrollbare WrapPanel met patiëntenkaarten -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="PnlPatienten" />
        </ScrollViewer>
    </Grid>
</Page>
