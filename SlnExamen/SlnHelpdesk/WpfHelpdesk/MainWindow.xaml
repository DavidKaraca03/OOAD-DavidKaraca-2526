<Window x:Class="WpfHelpdesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Helpdesk Ticketsysteem" Height="700" Width="1000"
        MinWidth="900" MinHeight="600">
    <DockPanel LastChildFill="True">

        <!-- TITELBALK -->
        <Border DockPanel.Dock="Top" Background="#2C3E50" Padding="15,10">
            <TextBlock Text="Helpdesk Ticketsysteem"
                       Foreground="White" FontSize="18" FontWeight="Bold"/>
        </Border>

        <!-- HOOFDINHOUD -->
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LINKERKOLOM: filters + lijst -->
            <DockPanel Grid.Column="0">

                <!-- FILTERS -->
                <GroupBox DockPanel.Dock="Top" Header="Filters" Margin="0,0,0,10" Padding="10">
                    <StackPanel>

                        <!-- Filter: Prioriteit -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Prioriteit:" Width="70" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmbPrioriteit" Width="150"
                                      SelectionChanged="Filter_Changed">
                                <ComboBoxItem Content="Alle" IsSelected="True"/>
                                <ComboBoxItem Content="Laag"/>
                                <ComboBoxItem Content="Normaal"/>
                                <ComboBoxItem Content="Hoog"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Filter: Melder -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Melder:" Width="70" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtFilterMelder" Width="150" Padding="4,2"
                                     TextChanged="Filter_Changed"/>
                        </StackPanel>

                        <!-- Filter: Alleen open tickets -->
                        <CheckBox x:Name="chkAlleenOpen" Content="Alleen open tickets"
                                  IsChecked="True" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    </StackPanel>
                </GroupBox>

                <!-- LIJST MET TICKETS -->
                <GroupBox Header="Tickets" Padding="5">
                    <ListBox x:Name="lbxTickets"
                             SelectionChanged="LbxTickets_SelectionChanged"
                             FontFamily="Consolas" FontSize="12"/>
                </GroupBox>
            </DockPanel>

            <!-- SPLITTER -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#CCCCCC"/>

            <!-- RECHTERKOLOM: details + nieuw ticket -->
            <DockPanel Grid.Column="2">

                <!-- NIEUW TICKET FORMULIER -->
                <GroupBox DockPanel.Dock="Bottom" Header="Nieuw ticket toevoegen"
                          Margin="0,10,0,0" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Titel -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Titel *:"
                                   VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtNieuwTitel" Grid.Row="0" Grid.Column="1"
                                 Grid.ColumnSpan="3" Padding="4,2" Margin="0,0,0,6"/>

                        <!-- Melder -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Melder *:"
                                   VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtNieuwMelder" Grid.Row="1" Grid.Column="1"
                                 Padding="4,2" Margin="0,0,5,6"/>

                        <!-- Prioriteit -->
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Prioriteit *:"
                                   VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <ComboBox x:Name="cmbNieuwPrioriteit" Grid.Row="1" Grid.Column="3"
                                  Margin="0,0,0,6">
                            <ComboBoxItem Content="Laag"/>
                            <ComboBoxItem Content="Normaal" IsSelected="True"/>
                            <ComboBoxItem Content="Hoog"/>
                        </ComboBox>

                        <!-- Type -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Type *:"
                                   VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <ComboBox x:Name="cmbNieuwType" Grid.Row="2" Grid.Column="1"
                                  Padding="4,2" Margin="0,0,5,6"
                                  SelectionChanged="CmbNieuwType_SelectionChanged">
                            <ComboBoxItem Content="Hardware" IsSelected="True"/>
                            <ComboBoxItem Content="Software"/>
                        </ComboBox>

                        <!-- Extra info label: Toestel of Applicatie afhankelijk van gekozen type -->
                        <TextBlock x:Name="lblExtraInfo" Grid.Row="2" Grid.Column="2"
                                   Text="Toestel *:" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtNieuwExtraInfo" Grid.Row="2" Grid.Column="3"
                                 Padding="4,2" Margin="0,0,0,6"/>

                        <!-- Foutmelding voor validatie -->
                        <TextBlock x:Name="lblFout" Grid.Row="3" Grid.Column="0"
                                   Grid.ColumnSpan="4" Foreground="Red"
                                   TextWrapping="Wrap" Margin="0,0,0,6"/>

                        <!-- Knop om nieuw ticket toe te voegen -->
                        <Button Grid.Row="4" Grid.Column="3" Content="Ticket toevoegen"
                                Padding="10,5" HorizontalAlignment="Right"
                                Click="BtnToevoegen_Click" Background="#27AE60"
                                Foreground="White" FontWeight="Bold"/>
                    </Grid>
                </GroupBox>

                <!-- DETAILPANEEL -->
                <GroupBox Header="Details" Padding="10">
                    <DockPanel>
                        <!-- Knop om geselecteerd ticket af te sluiten -->
                        <Button x:Name="btnAfsluiten" DockPanel.Dock="Bottom"
                                Content="Ticket afsluiten" Padding="10,6"
                                HorizontalAlignment="Right" Margin="0,10,0,0"
                                IsEnabled="False" Click="BtnAfsluiten_Click"
                                Background="#E74C3C" Foreground="White" FontWeight="Bold"/>

                        <!-- Detailtekst van het geselecteerde ticket -->
                        <TextBox x:Name="txtDetails"
                                 IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="13"
                                 TextWrapping="Wrap"
                                 Background="#F8F9FA"
                                 BorderThickness="0"
                                 Padding="5"
                                 Text="Selecteer een ticket om de details te zien."/>
                    </DockPanel>
                </GroupBox>

            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
